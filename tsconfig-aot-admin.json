{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"target": "es2022",
		"module": "es2022",
		"baseUrl": ".",
		"preserveConstEnums": false,
    	"paths": {
			"lodash": ["src/ts/lodash.ts"]
    	}
	},
	"files": [
		"src/ts/bootstrap-admin.ts"
	],
	"angularCompilerOptions": {
		"genDir": "src/ts",
		"skipMetadataEmit": true,
		"preserveWhitespaces": true
	}
}