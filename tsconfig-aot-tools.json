{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"target": "es5",
		"module": "es2015",
		"baseUrl": ".",
		"preserveConstEnums": false,
    	"paths": {
			"lodash": ["src/ts/lodash.ts"]
    	}
	},
	"files": [
		"src/ts/bootstrap-tools.ts"
	],
	"angularCompilerOptions": {
		"genDir": "src/ts",
		"skipMetadataEmit": true,
		"preserveWhitespaces": true
	}
}