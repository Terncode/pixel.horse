{
	"compilerOptions": {
		"target": "ES2020",
		"lib": [
			"dom",
			"ES2020"
		],
		"rootDir": "src/ts",
        "outDir": "src/scripts",
		"pretty": true,
		"module": "commonjs",
		"moduleResolution": "node",
		"importHelpers": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"declaration": false,
		"noEmitOnError": false,
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"noImplicitReturns": true,
		"strict": true,
		"strictFunctionTypes": true,
		"sourceMap": true,
		"preserveConstEnums": true,
    	"skipLibCheck": true
	},
	"exclude": [
		"build",
		"tools",
		"src/scripts",
		"node_modules"
	]
}
